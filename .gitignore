# ============================================================
#  Bluestock MF Capstone — .gitignore
#  Covers: Python, Jupyter Notebooks, VS Code, macOS
# ============================================================

# ---------------------------
# Python
# ---------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.manifest
*.spec

# Virtual environments
venv/
.venv/
env/
ENV/
.env
env.bak/
venv.bak/

# Environment variables & secrets
.env
.env.local
.env.*.local
secrets.ini
config_local.py

# ---------------------------
# Jupyter Notebooks
# ---------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py
*.ipynb_checkpoints

# ---------------------------
# VS Code
# ---------------------------
.vscode/
*.code-workspace
.history/

# ---------------------------
# Data files (large / sensitive)
# ---------------------------
# Raw source files — NOT committed (too large / source data)
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.json
data/raw/*.parquet

# Processed deliverable CSVs — COMMITTED so admin can verify on GitHub
# Only ignore large intermediates (clean_* aliases)
data/processed/clean_nav.csv
data/processed/clean_transactions.csv
data/processed/clean_performance.csv
data/processed/*.xlsx
data/processed/*.parquet
# Allow the 10 numbered deliverable CSVs (01_–10_)
!data/processed/01_fund_master.csv
!data/processed/02_nav_history.csv
!data/processed/03_aum_by_fund_house.csv
!data/processed/04_monthly_sip_inflows.csv
!data/processed/05_category_inflows.csv
!data/processed/06_industry_folio_count.csv
!data/processed/07_scheme_performance.csv
!data/processed/08_investor_transactions.csv
!data/processed/09_portfolio_holdings.csv
!data/processed/10_benchmark_indices.csv

# SQLite DB — committed as a deliverable (admin needs to see it)
!data/db/bluestock_mf.db
# WAL / SHM are transient lock files — still ignored
data/db/*.db-shm
data/db/*.db-wal
data/db/*.sqlite
data/db/*.sqlite3

# Allow placeholder .gitkeep files in data dirs
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/db/.gitkeep

# ---------------------------
# Reports & Outputs
# ---------------------------
reports/*.pdf
reports/*.html
reports/*.png
reports/*.jpg
# Allow Day 6 output chart
!reports/rolling_sharpe_chart.png

# ---------------------------
# Logs
# ---------------------------
*.log
logs/
*.out

# ---------------------------
# macOS
# ---------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.TemporaryItems

# ---------------------------
# Testing & Coverage
# ---------------------------
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
htmlcov/
.pytest_cache/
pytestdebug.log

# ---------------------------
# MyPy / Type Checkers
# ---------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# ---------------------------
# Misc
# ---------------------------
*.bak
*.swp
*.tmp
Thumbs.db
